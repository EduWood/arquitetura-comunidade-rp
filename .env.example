# Database (configurar em produção)
DATABASE_URL=postgresql://user:password@localhost:5432/comunidade_rp

# JWT Secrets (gerar valores aleatórios para produção)
JWT_SECRET=sua_jwt_secret_com_minimo_32_caracteres_aleatorios
REFRESH_TOKEN_SECRET=sua_refresh_token_secret_com_minimo_32_caracteres_aleatorios

# Sentry (opcional)
NEXT_PUBLIC_SENTRY_DSN=

# Email SMTP
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=seu_usuario
SMTP_PASS=sua_senha
SMTP_FROM=noreply@comunidade-rp.com

# APIs URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
