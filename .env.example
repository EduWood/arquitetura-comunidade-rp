# ========================================
# DATABASE
# ========================================
DATABASE_URL="mysql://user:password@localhost:3306/comunidade_rp"

# ========================================
# JWT
# ========================================
JWT_SECRET="sua-chave-super-secreta-min-32-caracteres-aqui"
JWT_EXPIRATION="24h"
JWT_REFRESH_EXPIRATION="7d"

# ========================================
# BCRYPT
# ========================================
BCRYPT_ROUNDS=10

# ========================================
# EMAIL (Para recuperação de senha)
# ========================================
SMTP_HOST="smtp.seu-email.com"
SMTP_PORT=587
SMTP_USER="seu-email@seu-dominio.com"
SMTP_PASSWORD="sua-senha-email"
SMTP_FROM="noreply@seu-dominio.com"

# ========================================
# UPSTASH REDIS (Rate Limiting)
# ========================================
UPSTASH_REDIS_REST_URL="https://seu-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="seu-token-aqui"

# ========================================
# CORS
# ========================================
ALLOWED_ORIGINS="http://localhost:3000,https://seu-dominio.com"

# ========================================
# APP
# ========================================
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Comunidade RP"

# ========================================
# SECURITY
# ========================================
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_TIME_MINUTES=15
EMAIL_VERIFICATION_ENABLED=true

# ========================================
# NODE ENV
# ========================================
NODE_ENV="development"

